# ============================================
# BEATIX BACKEND — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ============================================

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/beatix

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Flutterwave (Payments)
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# QR Code
QR_BASE_URL=https://yourdomain.com/scan

# Beatix Service Fee (as decimal — 0.05 = 5%)
SERVICE_FEE_RATE=0.05

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=5
